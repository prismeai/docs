#!/usr/bin/env bash
# Auto-run swagger transformations whenever api-reference/swagger.yml is staged.
# `npm install` configures `core.hooksPath` to this directory via the
# package.json `prepare` script — no manual step required.
set -euo pipefail

SPEC="api-reference/swagger.yml"

if git diff --cached --name-only | grep -qx "$SPEC"; then
  if ! command -v node >/dev/null 2>&1; then
    echo "pre-commit: node not found, skipping swagger transform" >&2
    exit 0
  fi
  if [ ! -d node_modules/yaml ]; then
    echo "pre-commit: node_modules/yaml not installed, skipping swagger transform" >&2
    echo "  run: npm install" >&2
    exit 0
  fi
  node .githooks/transform-swagger.mjs "$SPEC"
  git add "$SPEC"
fi
